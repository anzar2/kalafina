{
  "theme": "dark",
  "color": "auto",
  "fontFamily": "Ubuntu Sans",
  "fontScale": 1,
  "shellFrame": {
    "enabled": true,
    "borderWidth": 4,
    "borderRadius": 4
  },
  "workspaces": {
    "workspaceSpacing": 8,
    "iconSpacing": 4,
    "iconSize": 16,
    "radius": 24
  },
  "panel": {
    "size": 40,
    "position": "top",
    "start": {
      "moduleSpacing": 8
    },
    "center": {
      "moduleSpacing": 8
    },
    "end": {
      "moduleSpacing": 8
    }
  },
  "notifications": {
    "displayTime": 4000
  },
  "systemTray": {
    "padding": 5,
    "spacing": 8,
    "iconSize": 16
  },
  "osd": {
    "displayTime": 2500
  },
  "clock": {
    "horizontalFormat": "hh:mm",
    "verticalFormat": "hh\nmm",
    "fontSize": 15,
    "bold": true
  }
}
